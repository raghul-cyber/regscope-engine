# Database
DATABASE_URL=postgresql+asyncpg://regscope:password@postgres:5432/regscope

# Redis (Celery broker + result backend)
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=regscope_clauses

# Embedding model
EMBEDDING_MODEL=intfloat/multilingual-e5-large

# Crawler
CRAWLER_MAX_DEPTH=3
CRAWLER_REQUEST_DELAY_SECONDS=1.5
CRAWLER_MAX_PAGES_PER_DOMAIN=200

# OCR
OCR_CONFIDENCE_THRESHOLD=0.75
OCR_PRIMARY_ENGINE=easyocr

# Pipeline
CLASSIFIER_CONFIDENCE_THRESHOLD=0.55
VERIFIER_STRICT_MODE=true

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,https://regscope.yourdomain.com

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
